{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "claude-sessions",
  "version": "0.5.0",
  "identifier": "dev.nicsilver.claude-sessions",
  "build": {
    "frontendDist": "ui"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Claude sessions",
        "width": 328,
        "height": 240,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visibleOnAllWorkspaces": true,
        "acceptFirstMouse": true,
        "visible": false
      },
      {
        "label": "menu",
        "url": "menu.html",
        "title": "Claude sessions menu",
        "width": 224,
        "height": 240,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visibleOnAllWorkspaces": true,
        "acceptFirstMouse": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
