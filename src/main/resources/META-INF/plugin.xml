<idea-plugin>
    <id>com.nije.claude-sessions</id>
    <name>Claude Sessions</name>
    <vendor>nije</vendor>
    <description><![CDATA[
        Glanceable status for concurrent Claude Code sessions, with click-to-jump
        to the terminal tab that needs you. Reads ~/.claude/session-status/state.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.plugins.terminal</depends>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow id="Claude Sessions" anchor="right" secondary="false"
                    icon="AllIcons.Toolwindows.WebToolWindow"
                    factoryClass="com.nije.claudesessions.SessionsToolWindowFactory"/>
        <postStartupActivity implementation="com.nije.claudesessions.FocusWatcher"/>
    </extensions>

    <actions>
        <action id="com.nije.claudesessions.NewClaudeSession"
                class="com.nije.claudesessions.NewClaudeSessionAction"
                text="New Claude Session"
                description="Open a new terminal tab and run the 'clauded' alias">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <!-- No default shortcut: the new-chat hotkey is owned by the claude-sessions
                 menu-bar app (Settings…), so it's not duplicated in the IDE keymap. -->
        </action>
    </actions>
</idea-plugin>
